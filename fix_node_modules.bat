@echo off
REM ============================================================================
REM  Fix Corrupted Node Modules
REM ============================================================================

color 0A

echo.
echo ============================================================================
echo                    FIXING CORRUPTED NODE MODULES
echo ============================================================================
echo.

cd frontend

echo [1/5] Clearing npm cache...
call npm cache clean --force
echo [OK] Cache cleared

echo.
echo [2/5] Removing corrupted node_modules...
if exist node_modules (
    rmdir /s /q node_modules >nul 2>&1
    echo [OK] node_modules removed
) else (
    echo [OK] node_modules already removed
)

echo.
echo [3/5] Removing package-lock.json...
if exist package-lock.json (
    del package-lock.json >nul 2>&1
    echo [OK] package-lock.json removed
) else (
    echo [OK] package-lock.json already removed
)

echo.
echo [4/5] Reinstalling dependencies...
echo This may take 2-3 minutes...
call npm install --legacy-peer-deps
if errorlevel 1 (
    echo [WARNING] npm install had some warnings but continuing...
) else (
    echo [OK] Dependencies installed successfully
)

echo.
echo [5/5] Verifying installation...
if exist node_modules (
    echo [OK] node_modules folder exists
    if exist node_modules\vite (
        echo [OK] Vite is installed
    ) else (
        echo [ERROR] Vite is missing!
        pause
        exit /b 1
    )
) else (
    echo [ERROR] Installation failed!
    pause
    exit /b 1
)

cd ..

echo.
echo ============================================================================
echo                    FIX COMPLETE!
echo ============================================================================
echo.
echo Node modules have been cleaned and reinstalled.
echo.
echo Next steps:
echo   1. Double-click: run_scraper.bat
echo   2. Application should start normally
echo.
echo If you still get errors:
echo   1. Restart your computer
echo   2. Run this script again
echo.
echo ============================================================================
echo.

pause
exit /b 0
